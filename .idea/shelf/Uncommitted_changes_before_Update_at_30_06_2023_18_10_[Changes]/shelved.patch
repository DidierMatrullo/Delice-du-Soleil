--- /dev/null	(date 1688035510478)
+++ b/src/styles/layouts/_item.scss	(date 1688035510478)
@@ -0,0 +1,109 @@
+nav {
+  justify-content: center;
+}
+
+main {
+
+  .item-content {
+    display: grid;
+    grid-template-columns: 50% 50%;
+    width: 90%;
+    margin: 0 auto;
+
+    img {
+      width: 100%;
+      height: auto;
+    }
+
+    .item-description {
+      padding-left: 30px;
+      display: flex;
+      flex-direction: column;
+      justify-content: space-between;
+
+      h1 {
+        text-transform: uppercase;
+        color: $gold;
+        letter-spacing: 6px;
+        font-size: 4rem;
+      }
+
+      p {
+        font-size: 1.5rem;
+        line-height: 2.5rem;
+        text-align: left;
+      }
+
+      .item-selection {
+
+        table {
+
+          input {
+            display: inline-block;
+            vertical-align: middle;
+            width: 1.2rem;
+            height: 1.2rem;
+            accent-color: $gold;
+          }
+        }
+
+        td {
+          padding: 7px;
+        }
+
+        .add_to_cart_variants_option {
+          position: relative;
+
+          &:before {
+            content: "";
+            width: 1px;
+            background: #ffffff;
+            top: 0.5rem;
+            bottom: 0.5rem;
+            left: 0;
+            position: absolute;
+          }
+        }
+      }
+
+      .add_to_cart_qty_selection {
+
+        label {
+          padding-right: 10px;
+          text-transform: uppercase;
+        }
+
+        input[type='number'] {
+          width: 100px;
+          text-align: center;
+          padding: 5px;
+          font-size: 1rem;
+          background: #000;
+          color: #ffffff;
+
+          &:hover {
+            background: $gold;
+            color: $black1;
+          }
+        }
+      }
+    }
+
+    button {
+      text-transform: uppercase;
+      font-size: 1.5rem;
+      background: #000000;
+      padding: 10px 20px;
+      width: 100%;
+      color: #fff;
+      letter-spacing: 2px;
+
+      &:hover {
+        background: $gold;
+        color: $black1;
+      }
+    }
+  }
+}
+
+
